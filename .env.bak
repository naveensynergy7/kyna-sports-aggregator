# ---- Database Configuration (Docker MySQL) ----
DB_HOST=mysql
DB_USER=kyna_user
DB_PASSWORD=kyna_pass_123
DB_NAME=kyna_admin
DB_PORT=3306

# ---- Admin Dashboard Configuration ----
PORT=3000
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# ---- Telegram Watcher Configuration ----
WATCHER_CONTROL_PORT=3001
WATCHER_URL=http://localhost:3001

# ---- Environment ----
NODE_ENV=development
