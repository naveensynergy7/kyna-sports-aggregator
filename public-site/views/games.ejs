<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KYNA - Exceptional Jerseys</title>
    <link rel="stylesheet" href="/css/games.css" />
  </head>
  <body>
    <div class="container">
      <div id="page-loader">
        <img src="/public/images/loader.JPG" alt="Loading" />
        <div class="progress-bar-container">
          <div class="progress-bar-wrapper">
            <div class="progress-bar"></div>
          </div>
        </div>
      </div>

      <header class="main-header">
        <div class="logo">
          <h1>KYNA</h1>
        </div>
        <div class="tagline">EXCEPTIONAL JERSEYS<br />WITHOUT EXCEPTION</div>
      </header>

      <main>
        <section class="info-bar">
          <div class="date-weather">
            <div class="date" id="current-date">LOADING DATE...</div>
            <div class="weather-current">
              <div>
                <span class="icon" id="current-icon"></span>
                <span class="temp" id="current-temp">--°C</span>
              </div>
              <span class="condition" id="current-condition">LOADING...</span>
            </div>
          </div>
          <div class="time" id="current-time">--:--</div>
        </section>

        <section class="hero-section">
          <div class="forecast-panel" id="forecast-container">
            <h2>NEXT 4 DAYS</h2>
            <div class="forecast-item">
              <p>Loading forecast...</p>
            </div>
          </div>
          <div class="hero-image" aria-label="Woman wearing AS AUTO jersey"></div>
        </section>

        <section class="promo-banner">
          <div class="banner-placeholder">
            <a href="/games" class="banner-button" style="text-decoration: none; display: inline-block;">JOIN A GAME</a>
          </div>
        </section>

        <section class="train-services">
          <% if (typeof mrtLines !== 'undefined' && mrtLines && mrtLines.lines) { %>
            <div style="background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); padding: 20px; margin: 0 auto; max-width: 800px;">
              <div style="background-color: #dcecf2; padding: 15px 20px; margin: -20px -20px 20px -20px; border-radius: 8px 8px 0 0;">
                <h4 style="font-size: 18px; font-weight: 700; color: #000; margin: 0;">TRAIN SERVICE STATUS</h4>
              </div>
              <div style="font-size: 13px; color: #444; margin-bottom: 20px; padding-left: 0;">
                Last updated: <%= mrtLines.lastUpdated %>
              </div>
              <% if (mrtLines.error) { %>
                <div style="background-color: #fff3cd; border: 1px solid #ffc107; color: #856404; padding: 10px 15px; border-radius: 4px; margin-bottom: 20px; font-size: 14px;">
                  ⚠️ <%= mrtLines.error %>
                </div>
              <% } %>
              <% if (mrtLines.lines && mrtLines.lines.length > 0) { %>
                <ul style="list-style: none; padding: 0; margin: 0;">
                  <% mrtLines.lines.forEach(function(line) { %>
                    <li style="border-bottom: 1px solid #e0e0e0; padding: 15px 0;">
                      <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                        <div style="display: flex; align-items: center; gap: 15px;">
                          <% if (line.icon) { %>
                            <img src="<%= line.icon %>" alt="<%= line.name %>" style="width: 40px; height: auto; max-width: 40px; margin-right: 10px; display: inline-block; vertical-align: middle;" onerror="this.style.display='none'">
                          <% } %>
                          <span style="font-size: 16px; font-weight: 500;"><%= line.name %></span>
                        </div>
                        <% if (line.statusIcon) { %>
                          <img src="<%= line.statusIcon %>" alt="<%= line.status %> status" style="height: 18px; width: auto; margin-left: 8px;" onerror="this.style.display='none'">
                        <% } %>
                      </div>
                      <% if (line.message) { %>
                        <div style="font-size: 12px; color: #666; margin-top: 8px; text-align: left; display: block; line-height: 1.5;">
                          <span style="font-weight: 600; color: #333;"><%= line.message.boldPrefix %></span>
                          <% if (line.message.msg && line.message.msg !== line.message.status) { %>
                            <span style="color: #666; white-space: normal; word-break: break-word;"> <%= line.message.msg %></span>
                          <% } %>
                        </div>
                      <% } %>
                    </li>
                  <% }); %>
                </ul>
              <% } else { %>
                <div style="text-align: center; padding: 40px; color: #666;">No lines available</div>
              <% } %>
            </div>
          <% } else { %>
            <!-- Fallback to old display if mrtLines not available -->
            <div class="train-service-message">
              <div class="service-message-label">TRAIN SERVICE STATUS</div>
              <div class="service-message-content <%= trainService.hasAlert ? 'has-alert' : '' %>">
                <%= trainService.message || 'Normal service' %>
              </div>
            </div>
          <% } %>
        </section>

        <section class="weather-report">
          <h2>2-HOUR WEATHER REPORT</h2>

          <div class="region-report" id="region-north">
            <h3>NORTH</h3>
            <div class="report-details">
              <div class="locations">Loading...</div>
              <div class="conditions"></div>
            </div>
          </div>

          <div class="region-report" id="region-west">
            <h3>WEST</h3>
            <div class="report-details">
              <div class="locations">Loading...</div>
              <div class="conditions"></div>
            </div>
          </div>
        </section>
      </main>
    </div>
    <script src="/js/games.js"></script>
  </body>
</html>

