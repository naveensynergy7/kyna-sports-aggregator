<%- include('../layouts/main', {
    title: title,
    currentPage: 'dashboard',
    user: user,
    session: session,
    additionalStyles: `
        <style>
            .page-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 2rem;
                padding-bottom: 1rem;
                border-bottom: 2px solid #e9ecef;
            }

            .page-title {
                font-size: 2rem;
                font-weight: 600;
                color: var(--dark-color);
                margin: 0;
            }

            .empty-state {
                text-align: center;
                padding: 4rem 2rem;
                color: var(--secondary-color);
            }

            .empty-state i {
                font-size: 4rem;
                margin-bottom: 1rem;
                opacity: 0.5;
            }

            .empty-state h3 {
                margin-bottom: 1rem;
                color: var(--dark-color);
            }
        </style>
    `,
    body: `
        <div class="page-header">
            <h1 class="page-title">Dashboard</h1>
        </div>

        <div class="empty-state">
            <i class="bi bi-speedometer2"></i>
            <h3>Dashboard Coming Soon</h3>
            <p>Dashboard content will be added here later.</p>
        </div>
    `
}) %>